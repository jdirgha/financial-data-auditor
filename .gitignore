# Data — most outputs are regenerable by running the pipeline.
# We commit only:
#   - the 5 small summary tables that the notebook / README reference
#   - the AMZN and PFE comparison CSVs (used by the notebook's case study)
# Everything else is excluded so the repo stays lean.
data/raw/*
!data/raw/.gitkeep
data/splits/*
!data/splits/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/master_audit.csv
!data/processed/backtest_impact.csv
!data/processed/detector_counts.csv
!data/processed/diagnostics_summary.csv
!data/processed/threshold_sensitivity.csv
!data/processed/AMZN_comparison.csv
!data/processed/PFE_comparison.csv

# R
.Rproj.user/
.Rhistory
.RData
.Ruserdata
